# Worker URL — the print agent polls this for pending print jobs
WORKER_URL=https://caricature-booth.examples.workers.dev

# Event ID — scopes this agent to one event's print queue.
# Can also be passed as --event-id <slug> CLI flag (takes precedence).
EVENT_ID=nyc-2025

# How often to poll (ms). Default: 5000
POLL_INTERVAL_MS=5000

# How many jobs to fetch per poll. Default: 5
BATCH_SIZE=5

# Printer driver: "mock" (default) or "dnp" for DNP DS620A
PRINTER_DRIVER=mock

# CUPS printer name (only used when PRINTER_DRIVER=dnp).
# Find yours with: lpstat -p -d
# PRINTER_NAME=DNP_DS620
